import /vendor/etc/init/hw/init.audio.smartamp.rc
import /vendor/etc/init/hw/init.audio.fqc.rc
import /vendor/etc/init/hw/init.nfc.sec.rc

# SW4-HL-Display-ImplementCECTCABC-00+_20160126
import /vendor/etc/init/hw/init.lcm.rc

