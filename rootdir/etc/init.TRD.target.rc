import /vendor/etc/init/hw/init.fih.ramdump.rc

# HCLai add for ALT
import /vendor/etc/init/hw/init.alt.rc

on early-boot
  setprop debug.ftm.mixerpath /vendor/etc/mixer_paths_rhd.xml

# RSU Kinibi functions
